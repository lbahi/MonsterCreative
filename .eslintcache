t recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\screens\\DashboardScreen.tsx:127:5\n  125 |\n  126 |   useEffect(() => {\n> 127 |     fetchData();\n      |     ^^^^^^^^^ Avoid calling setState() directly within an effect\n  128 |   }, []);\n  129 |\n  130 |   useEffect(() => {",{"range":"19701","text":"16432"},{"range":"19702","text":"16432"},{"range":"19703","text":"16432"},{"range":"19704","text":"16432"},{"range":"19705","text":"16432"},"Replace `stats?.totalGenerations.toLocaleString()·??·'0'` with `(stats?.totalGenerations.toLocaleString()·??·'0')`",{"range":"19706","text":"19707"},{"range":"19708","text":"16432"},{"range":"19709","text":"16432"},{"range":"19710","text":"17828"},{"range":"19711","text":"17813"},"Replace `········` with `············`",{"range":"19712","text":"18273"},{"range":"19713","text":"18273"},{"range":"19714","text":"16432"},{"range":"19715","text":"16432"},{"range":"19716","text":"16432"},{"range":"19717","text":"16432"},"Replace `·style={{·display:·'flex',·alignItems:·'center',·justifyContent:·'space-between',·marginBottom:·6·}}` with `⏎··········style={{⏎············display:·'flex',⏎············alignItems:·'center',⏎············justifyContent:·'space-between',⏎············marginBottom:·6⏎··········}}⏎········`",{"range":"19718","text":"19719"},"Replace `·style={{·fontSize:·11,·color:·'rgba(255,255,255,0.3)',·letterSpacing:·'1px',·textTransform:·'uppercase'·}}` with `⏎··············style={{⏎················fontSize:·11,⏎················color:·'rgba(255,255,255,0.3)',⏎················letterSpacing:·'1px',⏎················textTransform:·'uppercase'⏎··············}}⏎············`",{"range":"19720","text":"19721"},"Replace `·alignItems:·'center',` with `⏎··············alignItems:·'center',⏎·············`",{"range":"19722","text":"19723"},"Replace `·border:·'1px·solid·var(--ma-border)',` with `⏎··············border:·'1px·solid·var(--ma-border)',⏎·············`",{"