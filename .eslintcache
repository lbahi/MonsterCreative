ge":"24131","text":"16432"},"Replace `·VIDEO_MODELS,·VIDEO_DURATIONS,·VIDEO_ASPECT_RATIOS,·VIDEO_RESOLUTIONS,·VIDEO_DEFAULTS,·VideoResolution·}·from·'./constants';␍` with `⏎··VIDEO_MODELS,⏎··VIDEO_DURATIONS,⏎··VIDEO_ASPECT_RATIOS,⏎··VIDEO_RESOLUTIONS,⏎··VIDEO_DEFAULTS,⏎··VideoResolution⏎}·from·'./constants'`",{"range":"24132","text":"24133"},{"range":"24134","text":"16432"},{"range":"24135","text":"16432"},{"range":"24136","text":"16432"},{"range":"24137","text":"16432"},{"range":"24138","text":"16432"},{"range":"24139","text":"16432"},{"range":"24140","text":"16432"},{"range":"24141","text":"16432"},{"range":"24142","text":"16432"},{"range":"24143","text":"16432"},{"range":"24144","text":"16432"},"Delete `··␍`",{"range":"24145","text":"16432"},{"range":"24146","text":"16432"},{"range":"24147","text":"16432"},{"range":"24148","text":"16432"},{"range":"24149","text":"16432"},{"range":"24150","text":"16432"},{"range":"24151","text":"16432"},{"range":"24152","text":"16432"},{"range":"24153","text":"16432"},{"range":"24154","text":"16432"},{"range":"24155","text":"16432"},{"range":"24156","text":"16432"},{"range":"24157","text":"16432"},{"range":"24158","text":"16432"},{"range":"24159","text":"16432"},{"range":"24160","text":"16432"},{"range":"24161","text":"16432"},{"range":"24162","text":"16432"},"Replace `null);␍` with `⏎····null⏎··)`",{"range":"24163","text":"24164"},{"range":"24165","text":"16432"},{"range":"24166","text":"16432"},{"range":"24167","text":"16432"},{"range":"24168","text":"16432"},{"range":"24169","text":"16432"},{"range":"24170","text":"16432"},{"range":"24171","text":"16432"},"Replace `·?·selectedModelInfo.pricePerSec.withAudio·:·selectedModelInfo.pricePerSec.noAudio;␍` with `⏎······?·selectedModelInfo.pricePerSec.withAudio⏎······:·selectedModelInfo.pricePerSec.noAudio`",{"range":"24172","text":"24173"},{"range":"24174","text":"16432"},{"range":"24175","text":"16432"},{"range":"24176","text":"16432"},{"range":"24177","text":"16432"},{"range":"24178","text":"16432"},"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\screens\\video-gen\\index.tsx:51:7\n  49 |   useEffect(() => {\n  50 |     if (!selectedModelInfo.supportedDurations.includes(duration)) {\n> 51 |       setDuration(selectedModelInfo.supportedDurations[0]);\n     |       ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  52 |     }\n  53 |   }, [selectedModelInfo, duration]);\n  54 |",{"range":"24179","text":"16432"},{"range":"24180","text":"16432"},{"range":"24181","text":"16432"},{"range":"24182","text":"16432"},{"range":"24183","text":"16432"},{"range":"24184","text":"16432"},{"range":"24185","text":"16432"},{"range":"24186","text":"16432"},{"range":"24187","text":"16432"},{"range":"24188","text":"16432"},{"range":"24189","text":"16432"},{"range":"24190","text":"16432"},"Replace `\"Please·upload·a·source·image·first.\");␍` with `'Please·upload·a·source·image·first.')`",{"range":"24191","text":"24192"},{"range":"24193","text":"16432"},{"range":"24194","text":"16432"},{"range":"24195","text":"16432"},{"range":"24196","text":"16432"},{"range":"24197","text":"16432"},{"range":"24198","text":"16432"},{"range":"24199","text":"16432"},{"range":"24200","text":"16432"},{"range":"24201","text":"16432"},{"range":"24202","text":"16432"},"Replace `\"Failed