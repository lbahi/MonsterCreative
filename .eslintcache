":"16432"},{"range":"18485","text":"16432"},{"range":"18486","text":"16432"},{"range":"18487","text":"16432"},{"range":"18488","text":"16432"},{"range":"18489","text":"16432"},{"range":"18490","text":"16432"},{"range":"18491","text":"16432"},{"range":"18492","text":"16432"},{"range":"18493","text":"16432"},{"range":"18494","text":"16432"},{"range":"18495","text":"16432"},{"range":"18496","text":"16432"},{"range":"18497","text":"16432"},{"range":"18498","text":"16432"},{"range":"18499","text":"16432"},{"range":"18500","text":"16432"},{"range":"18501","text":"16432"},{"range":"18502","text":"16432"},{"range":"18503","text":"16432"},{"range":"18504","text":"16432"},{"range":"18505","text":"16432"},{"range":"18506","text":"16432"},{"range":"18507","text":"16432"},{"range":"18508","text":"16432"},{"range":"18509","text":"16432"},{"range":"18510","text":"16432"},{"range":"18511","text":"16432"},{"range":"18512","text":"16432"},{"range":"18513","text":"16432"},{"range":"18514","text":"16432"},{"range":"18515","text":"16432"},"Replace `prev·=>·!prev);␍` with `(prev)·=>·!prev)`",{"range":"18516","text":"18517"},{"range":"18518","text":"16432"},{"range":"18519","text":"16432"},{"range":"18520","text":"16432"},{"range":"18521","text":"16432"},{"range":"18522","text":"16432"},{"range":"18523","text":"16432"},{"range":"18524","text":"16432"},{"range":"18525","text":"16432"},{"range":"18526","text":"16432"},{"range":"18527","text":"16432"},{"range":"18528","text":"16432"},{"range":"18529","text":"16432"},{"range":"18530","text":"16432"},{"range":"18531","text":"16432"},{"range":"18532","text":"16432"},{"range":"18533","text":"16432"},{"range":"18534","text":"16432"},{"range":"18535","text":"16432"},{"range":"18536","text":"16432"},{"range":"18537","text":"16432"},{"range":"18538","text":"16432"},{"range":"18539","text":"16432"},{"range":"18540","text":"16432"},{"range":"18541","text":"16432"},{"range":"18542","text":"16432"},{"range":"18543","text":"16432"},{"range":"18544","text":"16432"},{"range":"18545","text":"16432"},{"range":"18546","text":"16432"},{"range":"18547","text":"16432"},{"range":"18548","text":"16432"},{"range":"18549","text":"16432"},{"range":"18550","text":"16432"},{"range":"18551","text":"16432"},{"range":"18552","text":"16432"},{"range":"18553","text":"16432"},"react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\contexts\\AppContext.tsx:80:7\n  78 |   useEffect(() => {\n  79 |     if (localStorage.getItem('mosterads_onboarded') === 'true') {\n> 80 |       refreshConnectionStatus();\n     |       ^^^^^^^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  81 |     }\n  82 |   }, [refreshConnectionStatus]);\n  83 |",{"range":"18554","text":"16432"},{"range":"18555","text":"16432"},{"range":"18556","text":"16432"},{"range":"18557","text":"16432"},{"range":"18558","text":"16432"},"Replace `·value={{␍` with `⏎······value={{`",{"range":"18559","text":"18560"},"Replace `sidebarCollapsed,␍` with `··sidebarCollapsed,`",{"range":"18561","text":"18562"},"Replace `······setSidebarCollapsed,␍` with `········setSidebarCollapsed,`",{"range":"18563","text":"18564"},"Replace `······toggleSidebar,␍` with `········toggleSidebar,`",{"range":"18565","text":"18566"},"Replace `······rightPanelContent,␍` with `········rightPanelContent,`",{"range":"18567","text":"18568"},"Replace `······setRightPanelContent,␍` with `········setRightPanelContent,`",{"range":"18569","text":"18570"},"Replace `······onboardingComplete,␍` with `········onboardingComplete,`",{"range":"18571","text":"18572"},"Replace `completeOnboarding,␍` with `··completeOnboarding,`",{"range":"18573","text":"18574"},"Replace `······activeImageMode,␍` with `········activeImageMode,`",{"range":"18575","text":"18576"},"Replace `······setActiveImageMode,␍` with `········setActiveImageMode,`",{"range":"18577","text":"18578"},"Replace `······activeVideoMode,␍` with `········activeVideoMode,`",{"range":"18579","text":"18580"},"Replace `······setActiveVideoMode,␍` with `········setActiveVideoMode,`",{"range":"18581","text":"18582"},"Replace `······mcpEnabled,␍` with `········mcpEnabled,`",{"range":"18583","text":"18584"},"Replace `setMcpEnabled,␍` with `··setMcpEnabled,`",{"range":"18585","text":"18586"},"Replace `······connectionStatus,␍` with `········connectionStatus,`",{"range":"18587","text":"18588"},"Replace `······falCredits,␍` with `········falCredits,`",{"range":"18589","text":"18590"},"Replace `······refreshConnectionStatus,␍` with `········refreshConnectionStatus`",{"range":"18591","text":"18592"},"Replace `····}}>␍` with `······}}⏎····>`",{"range":"18593","text":"18594"},{"range":"18595","text":"16432"},{"range":"18596","text":"16432"},{"range":"18597","text":"16432"},{"range":"18598","text":"16432"},{"range":"18599","text":"16432"},"react-refresh/only-export-components","Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","namedExport",{"range":"18600","text":"16432"},{"range":"18601","text":"16432"},{"range":"18602","text":"16432"},{"range":"18603","text":"16432"},{"range":"18604","text":"16432"},{"range":"18605","text":"16432"},{"range":"18606","text":"16432"},{"range":"18607","text":"16432"},{"range":"18608","text":"16432"