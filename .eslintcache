1126"],["1127","1128"],["1129","1130"],["1131","1132"],["1133","1134"],["1135","1136"],"@typescript-eslint/ban-ts-comment","Include a description after the \"@ts-ignore\" directive to explain why the @ts-ignore is necessary. The description must be 3 characters or longer.","Line","tsDirectiveCommentRequiresDescription","react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\components\\Shell.tsx:30:7\n  28 |   useEffect(() => {\n  29 |     if (!licenseChecking && !onboardingComplete) {\n> 30 |       setShowOnboarding(true)\n     |       ^^^^^^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  31 |     }\n  32 |   }, [licenseChecking, onboardingComplete])\n  33 |","ArrowFunctionExpression",["1137","1138"],"react-refresh/only-export-components","Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","namedExport",["1139","1140"],["1141","1142"],["1143","1144"],["1145","1146"],["1147","1148"],["1149","1150"],["1151","1152"],["1153","1154"],["1155","1156"],["1157","1158"],["1159","1160"],["1161","1162"],"'ModelBreakdownItem' is defined but never used.",["1163"],["1164","1165"],["1166","1167"],["1168","1169"],["1170","1171"],["1172","1173"],["1174","1175"],["1176","1177"],["1178","1179"],["1180","1181"],["1182","1183"],["1184","1185"],"react-hooks/refs","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\screens\\audio-lab\\components\\UnifiedAudioPlayer.tsx:117:27\n  115 |               }}\n  116 |             >\n> 117 |               {formatTime(audioRef.current?.currentTime || 0)}\n      |                           ^^^^^^^^^^^^^^^^ Cannot access ref value during render\n  118 |             </span>\n  119 |             <span\n  120 |               style={{","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\screens\\audio-lab\\components\\UnifiedAudioPlayer.tsx:117:27\n  115 |               }}\n  116 |             >\n> 117 |               {formatTime(audioRef.current?.currentTime || 0)}\n      |                           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ Cannot access ref value during render\n  118 |             </span>\n  119 |             <span\n  120 |               style={{","Error: Cannot access refs during render\n\nReact refs are values that are not needed for rendering. Refs should only be accessed outside of render, such as in event handlers or effects. Accessing a ref value (the `current` property) during render can cause your component not to update as expected (https://react.dev/reference/react/useRef).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\screens\\audio-lab\\components\\UnifiedAudioPlayer.tsx:117:27\n  115 |               }}\n  116 |             >\n> 117 |               {formatTime(audioRef.current?.currentTime || 0)}\n      |                           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ Cannot access ref value during render\n  118 |             </span>\n  119 |             <span\n  120 |               style={{",["1186","1187"],"'UsageResponse' is defined but never used.",["1188"],"'activity' is assigned a value but never used.","'setActivity' is assigned a value but never used.","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\screens\\dashboard\\hooks\\useDashboard.ts:94:5\n  92 |\n  93 |   useEffect(() => {\n> 94 |     fetchData()\n     |     ^^^^^^^^^ Avoid calling setState() directly within an effect\n  95 |     // Auto-refresh every 2 minutes\n  96 |     const timer = setInterval(() => fetchData(true), 120000)\n  97 |     return () => clearInterval(timer)","react-hooks/exhaustive-deps","React Hook useEffect has a missing dependency: 'fetchData'. Either include it or remove the dependency array.","ArrayExpression",["1189"],"react/no-unescaped-entities","`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","JSXText","unescapedEntityAlts",["1190","1191","1192","1193"],["1194","1195"],["1196","1197"],"React Hook useEffect has missing dependencies: 'nbReferenceImage' and 'setSelectedOutput'. Either include them or remove the dependency array.",["1198"],["1199","1200"],["1201","1202"],"'err' is defined but never used.",["1203","1204"],["1205","1206"],"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nF:\\MosterAds\\MonsterCreative\\src\\renderer\\src\\screens\\video-gen\\hooks\\useVideoGen.ts:83:9\n  81 |       const defaultDur = selectedModelInfo.supportedDurations[0]\n  82 |       if (defaultDur !== undefined) {\n> 83 |         setDuration(defaultDur)\n     |         ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  84 |       }\n  85 |     }\n  86 |   }, [selectedModelInfo, duration])",{"messageId":"1207","fix":"1208","desc":"1209"},{"messageId":"1210","fix":"1211","desc":"1212"},{"messageId":"1213","data":"1214","fix":"1215","desc":"1216"},{"messageId":"1207","fix":"1217","desc":"1209"},{"messageId":"1210","fix":"1218","desc":"1212"},{"messageId":"1207","fix":"1219","desc":"1209"},{"messageId":"1210","fix":"1220","desc":"1212"},{"messageId":"1207","fix":"1221","desc":"1209"},{"messageId":"1210","fix":"1222","desc":"1212"},{"messageId":"1207","fix":"1223","desc":"1209"},{"messageId":"1210","fix":"1224","desc":"1212"},{"messageId":"1207","fix":"1225","desc":"1209"},{"messageId":"1210","f